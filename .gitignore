# Generated, not vendored: extracted from Qt's own resources by
# scripts/sync_qwebchannel.py so it always matches the installed Qt version.
frontend/public/qwebchannel.js

# (packaging/icons/*.png|ico are generated by scripts/make_icons.py but are
# committed: PyInstaller needs them at build time and they are 8 KB.)

# Never commit a workspace: it is someone's knowledge, and a private layer's
# objects are ciphertext that has no business in version control.
/workspace/
*.strata-workspace/
sbom-*.json
*.log

# Hypothesis (property-based testing) example database
.hypothesis/
